# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_PROXY=
TELEGRAM_CONNECTION_POOL_SIZE=32
TELEGRAM_CONNECT_TIMEOUT=20
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=30

# LLM 配置
# - 已知 provider: openai / deepseek / grok
# - 也支持任意 OpenAI-compatible provider，自定义 LLM_PROVIDER 名称并填写 LLM_BASE_URL / LLM_MODEL 即可
LLM_PROVIDER=grok
XAI_API_KEY=your_xai_api_key_here
# 非 Grok provider 使用 LLM_API_KEY
LLM_API_KEY=
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=your-grok-model
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# 示例：DeepSeek
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# 示例：Grok
# LLM_PROVIDER=grok
# XAI_API_KEY=your_xai_api_key_here
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL=your-grok-model

# 示例：自定义 OpenAI-compatible 服务
# LLM_PROVIDER=my-provider
# LLM_BASE_URL=https://your-llm-gateway.example.com/v1
# LLM_MODEL=your-model-name

# Redis
REDIS_URL=redis://localhost:6379/0

# MySQL
DATABASE_URL=mysql://root:password@localhost:3306/telegram_ai_character

# App
DEBUG=false
LOG_LEVEL=INFO
