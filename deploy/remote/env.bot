# Runtime environment for telegram-ai-bot
# Copy the same secret values from .env / env.app when deploying.

REDIS_URL=redis://redis:6379/0
DATABASE_URL=mysql://root:password@mysql:3306/telegram_ai_character
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WEAVIATE_HOST=weaviate
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051
LLM_PROVIDER=grok
XAI_API_KEY=your_xai_api_key_here
LLM_MODEL=grok-4-1-fast-reasoning
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_MODEL=deepseek-chat

# Keep Telegram traffic direct unless TELEGRAM_PROXY is explicitly required.
TELEGRAM_PROXY=
MINIAPP_URL=
COS_SECRET_ID=your_cos_secret_id_here
COS_SECRET_KEY=your_cos_secret_key_here
COS_BUCKET=roles-images-1308810419
COS_REGION=ap-singapore
COS_DOMAIN=roles-images-1308810419.cos.ap-singapore.myqcloud.com
COS_SIGN_EXPIRE=600

HTTP_PROXY=http://172.18.0.1:7890
HTTPS_PROXY=http://172.18.0.1:7890
NO_PROXY=127.0.0.1,localhost,mysql,redis,weaviate,text2vec-transformers
